# =============================================================================
# Certified Sliders — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Site URLs ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Claim Token Secret ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
CLAIM_TOKEN_SECRET=your-generated-secret

# --- Cloudflare Stream (video hosting) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_STREAM_SIGNING_KEY_ID=
CLOUDFLARE_STREAM_SIGNING_SECRET=

# --- Cloudflare R2 (video archival) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# --- Stripe (Coach Portal subscriptions) ---
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PREMIUM_PRICE_ID=price_xxx

# --- Sanity CMS (blog) ---
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_READ_TOKEN=

# --- Feature Flags ---
NEXT_PUBLIC_ENABLE_ADMIN_IMPERSONATION=false

# --- Development Only ---
# DEV_DEBUG_KEY=           # Enables /debug auth endpoints
# PROOF_BYPASS=true        # Bypasses proof whitelist in dev
# DATABASE_URL=            # For running migrations locally
